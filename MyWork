// ─────────────────────────────────────────────
// STATE
// ─────────────────────────────────────────────
let data = JSON.parse(localStorage.getItem('prk_works_data') || 'null') || JSON.parse(JSON.stringify(defaultData));
let editMode = false;
let modalSection = null;
let editingId = null;

function save() {
  localStorage.setItem('prk_works_data', JSON.stringify(data));
}

// ─────────────────────────────────────────────
// RENDER
// ─────────────────────────────────────────────
function renderAll() {
  renderExperience();
  renderProjects();
  renderCertifications();
  renderResearch();
  renderCreative();
  renderStrategy();
  renderWorkflow();
  updateCounts();
}

function cardActions(section, id) {
  return `
    <div class="card-actions">
      <button class="card-btn edit-btn" onclick="openModal('${section}',${id})" title="Edit">✏️</button>
      <button class="card-btn del-btn" onclick="deleteEntry('${section}',${id})" title="Delete">🗑️</button>
    </div>`;
}

function tagsHTML(tags) {
  if (!tags || !tags.length) return '';
  return `<div class="card-tags">${tags.map(t => `<span class="tag">${t}</span>`).join('')}</div>`;
}

function pointsHTML(points) {
  if (!points || !points.length) return '';
  return `<ul class="card-points">${points.map(p => `<li>${p}</li>`).join('')}</ul>`;
}

function renderExperience() {
  const el = document.getElementById('list-experience');
  if (!data.experience.length) { el.innerHTML = emptyState('No experience added yet.'); return; }
  el.innerHTML = data.experience.map(e => `
    <div class="work-card">
      ${cardActions('experience', e.id)}
      <div class="card-top">
        <div class="card-role">${e.role}</div>
        <div class="card-sub">${e.company}</div>
        <div class="card-date">${e.date}</div>
      </div>
      <div class="card-body">
        ${pointsHTML(e.points)}
        ${tagsHTML(e.tags)}
      </div>
    </div>`).join('');
}

function renderProjects() {
  const el = document.getElementById('list-projects');
  if (!data.projects.length) { el.innerHTML = emptyState('No projects added yet.'); return; }
  el.innerHTML = data.projects.map(e => `
    <div class="work-card">
      ${cardActions('projects', e.id)}
      <div class="card-top">
        <div class="card-role">${e.role}</div>
        <div class="card-sub">${e.company}</div>
        <div class="card-date">${e.date}</div>
      </div>
      <div class="card-body">
        ${pointsHTML(e.points)}
        ${tagsHTML(e.tags)}
        ${e.outcome ? `<div class="card-outcome">${e.outcome}</div>` : ''}
      </div>
    </div>`).join('');
}

function renderCertifications() {
  const el = document.getElementById('list-certifications');
  if (!data.certifications.length) { el.innerHTML = emptyState('No certifications added yet.'); return; }
  el.innerHTML = data.certifications.map(e => `
    <div class="cert-card" style="position:relative;">
      ${cardActions('certifications', e.id)}
      <div class="cert-badge">${e.emoji || '🎓'}</div>
      <div class="cert-info">
        <div class="cert-name">${e.name}</div>
        <div class="cert-issuer">${e.issuer}</div>
        <div class="cert-year">${e.year}</div>
      </div>
    </div>`).join('');
}

function renderResearch() { renderGeneric('research'); }
function renderCreative()  { renderGeneric('creative'); }
function renderStrategy()  { renderGeneric('strategy'); }
function renderWorkflow()  { renderGeneric('workflow'); }

function renderGeneric(section) {
  const el = document.getElementById('list-' + section);
  if (!data[section].length) { el.innerHTML = emptyState('Nothing added yet.'); return; }
  el.innerHTML = data[section].map(e => `
    <div class="work-card">
      ${cardActions(section, e.id)}
      <div class="card-top">
        <div class="card-role">${e.role}</div>
        <div class="card-sub">${e.company}</div>
        <div class="card-date">${e.date}</div>
      </div>
      <div class="card-body">
        ${pointsHTML(e.points)}
        ${tagsHTML(e.tags)}
        ${e.outcome ? `<div class="card-outcome">${e.outcome}</div>` : ''}
      </div>
    </div>`).join('');
}

function emptyState(msg) {
  return `<div class="empty-state"><div class="empty-icon">📭</div><p>${msg}<br/>Enable Edit Mode to add entries.</p></div>`;
}

function updateCounts() {
  ['experience','projects','certifications','research','creative','strategy','workflow'].forEach(s => {
    const el = document.getElementById('cnt-' + s);
    if (el) el.textContent = data[s].length;
  });
}

// ─────────────────────────────────────────────
// EDIT MODE
// ─────────────────────────────────────────────
function toggleEditMode() {
  editMode = !editMode;
  document.body.classList.toggle('edit-mode', editMode);
  const btn = document.getElementById('editToggle');
  btn.classList.toggle('active', editMode);
  btn.innerHTML = `<div class="edit-dot"></div>${editMode ? 'Exit Edit Mode' : 'Edit Mode'}`;
}

// ─────────────────────────────────────────────
// MODAL
// ─────────────────────────────────────────────
function openModal(section, id = null) {
  modalSection = section;
  editingId = id;
  const overlay = document.getElementById('modalOverlay');
  const title = document.getElementById('modalTitle');
  const form = document.getElementById('modalForm');

  let existing = null;
  if (id !== null) {
    existing = data[section].find(e => e.id === id);
  }

  const labels = {
    experience:     'Role / Position',
    projects:       'Project Name',
    certifications: 'Certification Name',
    research:       'Research Title',
    creative:       'Creative Work Title',
    strategy:       'Strategy / Framework Title',
    workflow:       'Workflow Name'
  };

  title.textContent = (id ? 'Edit' : 'Add') + ' — ' + section.charAt(0).toUpperCase() + section.slice(1);

  if (section === 'certifications') {
    form.innerHTML = `
      <div class="form-group">
        <label>Certification Name</label>
        <input id="f-name" type="text" placeholder="e.g. Google Ads Search Certification" value="${existing?.name||''}"/>
      </div>
      <div class="form-group">
        <label>Issuing Organisation</label>
        <input id="f-issuer" type="text" placeholder="e.g. Google, HubSpot, Coursera" value="${existing?.issuer||''}"/>
      </div>
      <div class="form-group">
        <label>Year</label>
        <input id="f-year" type="text" placeholder="e.g. 2024" value="${existing?.year||''}"/>
      </div>
      <div class="form-group">
        <label>Emoji Icon</label>
        <input id="f-emoji" type="text" placeholder="e.g. 🎓" value="${existing?.emoji||'🎓'}"/>
      </div>`;
  } else {
    form.innerHTML = `
      <div class="form-group">
        <label>${labels[section]||'Title'}</label>
        <input id="f-role" type="text" placeholder="Enter title..." value="${existing?.role||''}"/>
      </div>
      <div class="form-group">
        <label>Organisation / Context</label>
        <input id="f-company" type="text" placeholder="Company, client, or project type..." value="${existing?.company||''}"/>
      </div>
      <div class="form-group">
        <label>Date / Period</label>
        <input id="f-date" type="text" placeholder="e.g. Jan 2024 – Present" value="${existing?.date||''}"/>
      </div>
      <div class="form-group">
        <label>Key Points</label>
        <textarea id="f-points" placeholder="One point per line...">${existing?.points?.join('\n')||''}</textarea>
        <div class="form-note">Enter each bullet point on a new line.</div>
      </div>
      <div class="form-group">
        <label>Tags / Skills (comma separated)</label>
        <input id="f-tags" type="text" placeholder="e.g. Google Ads, Meta, Analytics" value="${existing?.tags?.join(', ')||''}"/>
      </div>
      ${section !== 'experience' && section !== 'workflow' ? `
      <div class="form-group">
        <label>Outcome / Result (optional)</label>
        <input id="f-outcome" type="text" placeholder="e.g. 🏅 Top-performing project" value="${existing?.outcome||''}"/>
      </div>` : ''}`;
  }

  overlay.classList.add('open');
}

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('open');
  modalSection = null; editingId = null;
}

function saveEntry() {
  const section = modalSection;

  if (section === 'certifications') {
    const entry = {
      id: editingId || Date.now(),
      name:   document.getElementById('f-name').value.trim(),
      issuer: document.getElementById('f-issuer').value.trim(),
      year:   document.getElementById('f-year').value.trim(),
      emoji:  document.getElementById('f-emoji').value.trim() || '🎓'
    };
    if (!entry.name) return alert('Please enter a certification name.');
    upsert(section, entry);
  } else {
    const pointsRaw = document.getElementById('f-points').value;
    const tagsRaw   = document.getElementById('f-tags').value;
    const entry = {
      id:      editingId || Date.now(),
      role:    document.getElementById('f-role').value.trim(),
      company: document.getElementById('f-company').value.trim(),
      date:    document.getElementById('f-date').value.trim(),
      points:  pointsRaw.split('\n').map(p=>p.trim()).filter(Boolean),
      tags:    tagsRaw.split(',').map(t=>t.trim()).filter(Boolean),
      outcome: document.getElementById('f-outcome')?.value.trim() || ''
    };
    if (!entry.role) return alert('Please enter a title.');
    upsert(section, entry);
  }

  save();
  renderAll();
  closeModal();
}

function upsert(section, entry) {
  const idx = data[section].findIndex(e => e.id === entry.id);
  if (idx >= 0) data[section][idx] = entry;
  else data[section].push(entry);
}

function deleteEntry(section, id) {
  if (!confirm('Delete this entry?')) return;
  data[section] = data[section].filter(e => e.id !== id);
  save();
  renderAll();
}

// ─────────────────────────────────────────────
// SIDEBAR ACTIVE STATE
// ─────────────────────────────────────────────
const sections = ['experience','projects','certifications','research','creative','strategy','workflow'];

window.addEventListener('scroll', () => {
  let current = sections[0];
  sections.forEach(id => {
    const el = document.getElementById(id);
    if (el && window.scrollY >= el.offsetTop - 120) current = id;
  });
  document.querySelectorAll('.sidebar-link').forEach(l => {
    l.classList.toggle('active', l.dataset.section === current);
  });
});

// close modal on overlay click
document.getElementById('modalOverlay').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// reveal on scroll
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }});
}, { threshold: 0.08 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// ─────────────────────────────────────────────
// INIT
// ─────────────────────────────────────────────
renderAll();
</script>
